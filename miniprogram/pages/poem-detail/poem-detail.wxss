/* pages/poem-detail/poem-detail.wxss */

.page-root {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #FAF7F2;
}

/* ===== 导航栏 ===== */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 24rpx;
  background-color: #FAF7F2;
  border-bottom: 1rpx solid rgba(158, 148, 136, 0.15);
  flex-shrink: 0;
}

.nav-back {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.nav-back-icon {
  font-size: 26rpx;
  color: #6B5B4F;
}

.nav-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D2B1F;
  letter-spacing: 2rpx;
}

.nav-placeholder {
  width: 60rpx;
}

/* ===== 内容滚动区 ===== */
.content-scroll {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.poem-container {
  padding: 32rpx 32rpx calc(140rpx + env(safe-area-inset-bottom));
}

/* ===== 诗词标题区 ===== */
.poem-header {
  text-align: center;
  margin-bottom: 40rpx;
  padding-bottom: 32rpx;
  border-bottom: 1rpx solid rgba(158, 148, 136, 0.15);
}

.poem-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #3D2B1F;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
  font-family: serif;
}

.poem-meta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.poem-dynasty {
  font-size: 24rpx;
  color: rgba(107, 91, 79, 0.6);
  padding: 4rpx 12rpx;
  background-color: rgba(158, 148, 136, 0.1);
  border-radius: 8rpx;
}

.poem-author {
  font-size: 26rpx;
  color: #6B5B4F;
  font-weight: 500;
}

/* ===== 原文区 ===== */
.poem-content-section {
  margin-bottom: 32rpx;
  padding: 32rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(61, 43, 31, 0.04);
}

.section-label {
  font-size: 22rpx;
  color: rgba(107, 91, 79, 0.5);
  margin-bottom: 20rpx;
  letter-spacing: 4rpx;
}

.poem-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.poem-line {
  display: block;
  font-size: 34rpx;
  color: #3D2B1F;
  line-height: 1.8;
  letter-spacing: 4rpx;
  text-align: center;
  font-family: serif;
}

/* ===== 折叠区块 ===== */
.poem-section {
  margin-bottom: 20rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(61, 43, 31, 0.04);
  overflow: hidden;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background-color: rgba(250, 247, 242, 0.5);
  border-bottom: 1rpx solid rgba(158, 148, 136, 0.08);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3D2B1F;
  letter-spacing: 4rpx;
}

.section-toggle {
  font-size: 22rpx;
  color: #6B5B4F;
  padding: 6rpx 16rpx;
  background-color: rgba(158, 148, 136, 0.1);
  border-radius: 12rpx;
}

.section-body {
  padding: 24rpx 32rpx;
}

/* ===== 注释 ===== */
.annotation-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
  line-height: 1.6;
}

.annotation-item:last-child {
  margin-bottom: 0;
}

.annotation-word {
  font-size: 26rpx;
  font-weight: 600;
  color: #3D2B1F;
  flex-shrink: 0;
  min-width: 60rpx;
}

.annotation-meaning {
  font-size: 26rpx;
  color: #6B5B4F;
  line-height: 1.6;
}

/* ===== 译文和赏析 ===== */
.poem-translation,
.poem-appreciation,
.poem-background {
  display: block;
  font-size: 28rpx;
  color: #3D2B1F;
  line-height: 1.8;
  letter-spacing: 2rpx;
  text-align: justify;
}

/* ===== 标签 ===== */
.poem-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 32rpx;
  padding: 0 8rpx;
}

.poem-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 20rpx;
  font-size: 22rpx;
  color: #6B5B4F;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  border: 1rpx solid rgba(158, 148, 136, 0.2);
}

/* ===== 底部操作栏 ===== */
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background-color: #FFFFFF;
  border-top: 1rpx solid rgba(158, 148, 136, 0.15);
  box-shadow: 0 -4rpx 20rpx rgba(61, 43, 31, 0.06);
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  border-radius: 36rpx;
  transition: all 0.2s ease;
}

.copy-btn {
  color: #6B5B4F;
  background-color: rgba(250, 247, 242, 0.9);
  border: 1rpx solid rgba(158, 148, 136, 0.3);
}

.copy-btn.copied {
  color: #4A7C59;
  background-color: rgba(74, 124, 89, 0.08);
  border-color: rgba(74, 124, 89, 0.2);
}

.luomo-btn {
  color: #FAF7F2;
  background-color: #6B5B4F;
  border: none;
}

.luomo-btn:active {
  opacity: 0.85;
}
