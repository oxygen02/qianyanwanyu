/* pages/poem-detail/poem-detail.wxss */

.page-root {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #E8E0D4;
}

/* ===== 顶部安全区域占位 ===== */
.safe-area-top {
  width: 100%;
  flex-shrink: 0;
  background-color: #E8E0D4;
}

/* ===== 内容滚动区 ===== */
.content-scroll {
  flex: 1;
  min-height: 0;
  padding: 16rpx 24rpx;
  overflow: hidden;
  box-sizing: border-box;
}

/* ===== 书页纸张 ===== */
.paper-sheet {
  background-color: #FAF7F2;
  border-radius: 8rpx;
  padding: 32rpx 28rpx;
  box-shadow:
    0 1rpx 3rpx rgba(0, 0, 0, 0.12),
    0 4rpx 12rpx rgba(0, 0, 0, 0.08),
    inset 0 0 60rpx rgba(139, 119, 101, 0.05);
  position: relative;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

/* 纸张边缘做旧效果 */
.paper-sheet::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 8rpx;
  pointer-events: none;
  box-shadow: inset 0 0 30rpx rgba(158, 148, 136, 0.15);
}

/* ===== 诗词标题 ===== */
.poem-header {
  text-align: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(158, 148, 136, 0.25);
}

.poem-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #2C1810;
  letter-spacing: 10rpx;
  margin-bottom: 12rpx;
  font-family: 'Songti SC', 'SimSun', serif;
}

.poem-meta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.poem-dynasty {
  font-size: 22rpx;
  color: rgba(107, 91, 79, 0.7);
  padding: 4rpx 12rpx;
  background-color: rgba(158, 148, 136, 0.12);
  border-radius: 6rpx;
}

.poem-author {
  font-size: 26rpx;
  color: #5C4A3D;
  font-weight: 500;
}

/* ===== 原文 ===== */
.poem-content {
  margin-bottom: 24rpx;
  padding: 20rpx 16rpx;
  background-color: rgba(255, 255, 255, 0.4);
  border-radius: 8rpx;
  border: 1rpx solid rgba(158, 148, 136, 0.15);
}

.poem-line {
  display: block;
  font-size: 28rpx;
  color: #2C1810;
  line-height: 1.8;
  letter-spacing: 4rpx;
  text-align: center;
  font-family: 'Songti SC', 'SimSun', serif;
  word-wrap: break-word;
  overflow-wrap: break-word;
}

/* ===== 各区块 ===== */
.poem-section {
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #4A3728;
  letter-spacing: 4rpx;
  margin-bottom: 10rpx;
  padding-left: 10rpx;
  border-left: 3rpx solid #8B7355;
}

.section-body {
  padding: 12rpx;
  background-color: rgba(255, 255, 255, 0.3);
  border-radius: 6rpx;
  overflow: hidden;
}

.section-text {
  display: block;
  font-size: 24rpx;
  color: #4A3728;
  line-height: 1.6;
  letter-spacing: 1rpx;
  text-align: justify;
  word-wrap: break-word;
  overflow-wrap: break-word;
}

/* ===== 注释 ===== */
.annotation-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 6rpx;
  line-height: 1.5;
  word-wrap: break-word;
  overflow-wrap: break-word;
}

.annotation-item:last-child {
  margin-bottom: 0;
}

.annotation-word {
  font-size: 24rpx;
  font-weight: 600;
  color: #2C1810;
  flex-shrink: 0;
  min-width: 50rpx;
  font-family: 'Songti SC', 'SimSun', serif;
}

.annotation-meaning {
  font-size: 24rpx;
  color: #5C4A3D;
  line-height: 1.5;
  word-wrap: break-word;
  overflow-wrap: break-word;
}

/* ===== 标签 ===== */
.poem-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(158, 148, 136, 0.2);
}

.poem-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 14rpx;
  font-size: 20rpx;
  color: #6B5B4F;
  background-color: rgba(158, 148, 136, 0.1);
  border-radius: 14rpx;
  border: 1rpx solid rgba(158, 148, 136, 0.2);
}

/* ===== 底部诗词切换导航栏 ===== */
.poem-nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 12rpx 0 calc(12rpx + env(safe-area-inset-bottom));
  background-color: #F5F0E8;
  border-top: 1rpx solid rgba(158, 148, 136, 0.2);
  flex-shrink: 0;
}

.poem-nav-item {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  position: relative;
}

.poem-nav-item.disabled {
  opacity: 0.35;
}

.poem-nav-center {
  border-left: 1rpx solid rgba(158, 148, 136, 0.2);
  border-right: 1rpx solid rgba(158, 148, 136, 0.2);
}

.poem-nav-icon {
  font-size: 28rpx;
  color: #6B5B4F;
  line-height: 1;
}

.poem-nav-text {
  font-size: 28rpx;
  color: #6B5B4F;
  font-family: serif;
  letter-spacing: 0.1em;
}

/* 选中指示条 */
.poem-nav-item:active {
  background-color: rgba(158, 148, 136, 0.15);
}
