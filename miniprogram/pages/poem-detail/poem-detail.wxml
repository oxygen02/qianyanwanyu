<!-- pages/poem-detail/poem-detail.wxml -->
<view class="page-root">
  <!-- 固定区域：诗词标题和正文 -->
  <view class="poem-fixed-area" wx:if="{{poem}}">
    <view class="paper-sheet-fixed">
      <!-- 诗词标题 -->
      <view class="poem-header">
        <text class="poem-title">{{poem.title}}</text>
        <view class="poem-meta">
          <text class="poem-dynasty" wx:if="{{poem.dynasty}}">{{poem.dynasty}}</text>
          <text class="poem-author" wx:if="{{poem.author}}">{{poem.author}}</text>
        </view>
      </view>

      <!-- 原文 -->
      <view class="poem-content {{poem.alignClass}}">
        <text class="poem-line" wx:for="{{poem.lines}}" wx:key="index">{{item}}</text>
        <view class="copy-btn" bindtap="onCopyPoem">
          <image class="copy-icon-img" src="/images/copy.png" mode="aspectFit" />
        </view>
      </view>
    </view>
  </view>

  <!-- 滚动区域：注释、译文、赏析等 -->
  <scroll-view scroll-y class="content-scroll" enhanced show-scrollbar="{{false}}" wx:if="{{poem}}">
    <view class="paper-sheet-scroll">
      <!-- 注释 -->
      <view class="poem-section" wx:if="{{poem.annotations}}">
        <view class="section-title">注释</view>
        <view class="section-body">
          <view class="annotation-item" wx:for="{{poem.annotations}}" wx:key="index" wx:for-item="value" wx:for-index="key">
            <text class="annotation-word">{{key}}</text>
            <text class="annotation-meaning">：{{value}}</text>
          </view>
        </view>
      </view>

      <!-- 译文 -->
      <view class="poem-section" wx:if="{{poem.translation}}">
        <view class="section-title">译文</view>
        <view class="section-body">
          <text class="section-text">{{poem.translation}}</text>
        </view>
      </view>

      <!-- 赏析 -->
      <view class="poem-section" wx:if="{{poem.appreciation}}">
        <view class="section-title">赏析</view>
        <view class="section-body">
          <text class="section-text">{{poem.appreciation}}</text>
        </view>
      </view>

      <!-- 创作背景 -->
      <view class="poem-section" wx:if="{{poem.backgroundStory}}">
        <view class="section-title">创作背景</view>
        <view class="section-body">
          <text class="section-text">{{poem.backgroundStory}}</text>
        </view>
      </view>

      <!-- 标签 -->
      <view class="poem-tags" wx:if="{{poem.tags && poem.tags.length > 0}}">
        <text class="poem-tag" wx:for="{{poem.tags}}" wx:key="*this">{{item}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 底部诗词切换导航栏 -->
  <view class="poem-nav-bar" wx:if="{{poem}}" catchtouchmove="preventTouchMove">
    <view class="poem-nav-item {{currentIndex === 0 ? 'disabled' : ''}}" bindtap="onPrevPoem">
      <text class="poem-nav-text">上一篇</text>
    </view>
    <view class="poem-nav-item poem-nav-center" bindtap="onRandomPoem">
      <text class="poem-nav-text">漫游</text>
    </view>
    <view class="poem-nav-item {{currentIndex === totalCount - 1 ? 'disabled' : ''}}" bindtap="onNextPoem">
      <text class="poem-nav-text">下一篇</text>
    </view>
  </view>

  <!-- 首页导航栏 -->
  <view class="home-tab-bar">
    <view class="home-tab-item {{activeTab === 'luomo' ? 'active' : ''}}" bindtap="onGoLuomo">
      <text class="home-tab-text">落墨</text>
    </view>
    <view class="home-tab-item {{activeTab === 'wendian' ? 'active' : ''}}" bindtap="onGoWendian">
      <text class="home-tab-text">问典</text>
    </view>
    <view class="home-tab-item {{activeTab === 'wujuan' ? 'active' : ''}}" bindtap="onGoWujuan">
      <text class="home-tab-text">吾卷</text>
    </view>
  </view>
</view>
