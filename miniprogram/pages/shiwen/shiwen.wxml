<!-- pages/shiwen/shiwen.wxml -->
<!-- 拾文：粘贴文章/网址，自动提取正文，图片单独插画页 -->
<view class="page-root">

  <!-- 顶部标题区 -->
  <view class="header" style="padding-top:{{statusBarHeight}}px">
    <text class="header-title">拾文</text>
    <text class="header-sub">粘贴文章，化为书页</text>
  </view>

  <!-- 状态1：输入 -->
  <view class="paste-area" wx:if="{{stage === 'input'}}">
    <view class="paste-card">
      <textarea
        class="paste-textarea"
        value="{{rawInput}}"
        placeholder="粘贴文章正文或网址链接..."
        placeholder-class="paste-placeholder"
        bindinput="onInputChange"
        auto-height="{{false}}"
        maxlength="{{-1}}"
        show-confirm-bar="{{false}}"
        adjust-position="{{false}}"
      />
      <view class="paste-actions">
        <view class="paste-btn" bind:tap="onPasteFromClipboard">
          <text class="paste-btn-text">从剪贴板粘贴</text>
        </view>
      </view>
    </view>

    <view class="paste-tips">
      <text class="tips-title">使用提示</text>
      <text class="tips-item">1. 粘贴微信公众号、知乎、博客文章链接，自动提取正文</text>
      <text class="tips-item">2. 或长按复制全文，粘贴到上方文本框</text>
      <text class="tips-item">3. 铅言万语自动清洗广告，图片单独成页</text>
    </view>

    <view class="bottom-bar">
      <view
        class="generate-btn {{rawInput ? 'active' : 'disabled'}}"
        bind:tap="onExtract"
      >
        <text class="generate-btn-text">生成书页</text>
      </view>
    </view>
  </view>

  <!-- 状态2：加载中 -->
  <view class="loading-area" wx:if="{{stage === 'loading'}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在提取内容...</text>
    <text class="loading-sub">自动识别正文，清洗无关内容</text>
  </view>

  <!-- 状态3：预览（书页浏览） -->
  <view class="preview-area" wx:if="{{stage === 'preview'}}">
    <!-- 文章信息栏 -->
    <view class="article-info" wx:if="{{articleTitle || wordCount > 0}}">
      <text class="article-title" wx:if="{{articleTitle}}">{{articleTitle}}</text>
      <view class="article-meta">
        <text class="article-author" wx:if="{{articleAuthor}}">{{articleAuthor}}</text>
        <text class="article-stat">{{wordCount}} 字</text>
        <text class="article-pages">{{totalPages}} 页</text>
      </view>
      <view class="clean-info" wx:if="{{removedAds.length > 0}}">
        <text class="clean-badge">已清洗 {{removedAds.length}} 处推广内容</text>
      </view>
    </view>

    <!-- 书页Canvas区域（支持触摸翻页） -->
    <view
      class="book-page-container"
      bindtouchstart="onTouchStart"
      bindtouchend="onTouchEnd"
      bindtap="onTapPage"
    >
      <canvas
        id="shiwenCanvas"
        type="2d"
        class="book-canvas"
        style="width:{{canvasWidth}}px;height:{{canvasHeight}}px"
      />

      <!-- 翻页提示遮罩 -->
      <view class="page-hint left-hint" wx:if="{{currentPageIndex > 0}}">
        <text class="hint-arrow">&#8249;</text>
      </view>
      <view class="page-hint right-hint" wx:if="{{currentPageIndex < totalPages - 1}}">
        <text class="hint-arrow">&#8250;</text>
      </view>

      <!-- 渲染中遮罩 -->
      <view class="rendering-mask" wx:if="{{isRendering}}">
        <view class="rendering-spinner"></view>
      </view>
    </view>

    <!-- 页码指示器 -->
    <view class="page-indicator" wx:if="{{totalPages > 1}}">
      <view
        wx:for="{{allPages}}"
        wx:key="index"
        class="page-dot {{index === currentPageIndex ? 'active' : ''}} {{item.type === 'image' ? 'image-dot' : ''}}"
        bind:tap="_goToPage"
        data-page="{{index}}"
      />
    </view>

    <!-- 当前页类型标识 -->
    <view class="page-type-badge" wx:if="{{allPages[currentPageIndex].type === 'image'}}">
      <text class="page-type-text">插图</text>
    </view>

    <!-- 模板选择 -->
    <view class="template-bar">
      <text class="template-bar-label">纸张</text>
      <scroll-view scroll-x class="template-mini-scroll">
        <view class="template-mini-list">
          <view
            wx:for="{{templateList}}"
            wx:key="id"
            class="template-mini-item {{item.id === activeTemplateId ? 'active' : ''}}"
            bind:tap="onSelectTemplate"
            data-id="{{item.id}}"
            style="background-color:{{item.paper.baseColor}}"
          >
            <text class="template-mini-name">{{item.name}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 底部操作栏 -->
    <view class="bottom-bar preview-bottom">
      <view class="preview-actions">
        <view class="action-btn secondary" bind:tap="onBackToInput">
          <text>重新输入</text>
        </view>
        <view class="action-btn primary" bind:tap="onExport">
          <text>{{isExporting ? '导出中...' : '保存到相册'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 状态4：完成 -->
  <view class="success-area" wx:if="{{stage === 'done'}}">
    <view class="success-icon-wrap">
      <text class="success-icon">卷</text>
    </view>
    <text class="success-title">书页已生成</text>
    <text class="success-sub">已保存到相册，可在吾卷中查看历史</text>
    <view class="success-actions">
      <view class="success-btn secondary" bind:tap="onReset">
        <text>继续拾文</text>
      </view>
      <view class="success-btn primary" bind:tap="onGoToLuomo">
        <text>回到落墨</text>
      </view>
    </view>
  </view>

</view>
