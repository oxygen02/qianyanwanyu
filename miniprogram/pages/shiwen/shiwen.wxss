/* pages/shiwen/shiwen.wxss */

.page-root {
  width: 100%;
  min-height: 100vh;
  background-color: #F5F0E8;
  display: flex;
  flex-direction: column;
}

/* ---- 顶部标题 ---- */
.header {
  padding: 20rpx 40rpx 24rpx;
  background-color: #F5F0E8;
}

.header-title {
  display: block;
  font-size: 44rpx;
  color: #3D2B1F;
  font-family: serif;
  font-weight: 500;
  letter-spacing: 0.08em;
}

.header-sub {
  display: block;
  font-size: 24rpx;
  color: #9E9488;
  margin-top: 6rpx;
  letter-spacing: 0.06em;
}

/* ---- 粘贴区域 ---- */
.paste-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 0 32rpx;
  gap: 32rpx;
}

.paste-card {
  background-color: #FAF7F2;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.paste-textarea {
  width: 100%;
  min-height: 300rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #3D2B1F;
  font-family: serif;
  background-color: transparent;
  border: none;
}

.paste-placeholder {
  color: rgba(158, 148, 136, 0.6);
  font-family: serif;
}

.paste-actions {
  margin-top: 24rpx;
  display: flex;
  justify-content: center;
}

.paste-btn {
  background-color: rgba(61, 43, 31, 0.08);
  border-radius: 40rpx;
  padding: 16rpx 40rpx;
}

.paste-btn-text {
  font-size: 26rpx;
  color: #3D2B1F;
}

/* ---- 提示文字 ---- */
.paste-tips {
  background-color: rgba(158, 148, 136, 0.1);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
}

.tips-title {
  display: block;
  font-size: 24rpx;
  color: #9E9488;
  margin-bottom: 16rpx;
  letter-spacing: 0.05em;
}

.tips-item {
  display: block;
  font-size: 24rpx;
  color: #9E9488;
  line-height: 1.8;
}

/* ---- 底部按钮 ---- */
.bottom-bar {
  padding: 24rpx 0 48rpx;
}

.generate-btn {
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.2s;
}

.generate-btn.active {
  background-color: #3D2B1F;
}

.generate-btn.disabled {
  background-color: rgba(61, 43, 31, 0.25);
  pointer-events: none;
}

.generate-btn-text {
  font-size: 32rpx;
  color: #FAF7F2;
  font-family: serif;
  letter-spacing: 0.1em;
}

/* ---- 预览区域 ---- */
.preview-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 0 32rpx;
  gap: 24rpx;
}

.preview-info {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.preview-stat {
  font-size: 24rpx;
  color: #9E9488;
}

.preview-revert {
  font-size: 24rpx;
  color: #3D2B1F;
  text-decoration: underline;
}

.preview-card {
  flex: 1;
  background-color: #FAF7F2;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  min-height: 360rpx;
}

.preview-textarea {
  width: 100%;
  height: 100%;
  min-height: 300rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #3D2B1F;
  font-family: serif;
  background-color: transparent;
}

/* ---- 模板选择横条 ---- */
.template-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
}

.template-bar-label {
  font-size: 24rpx;
  color: #9E9488;
  flex-shrink: 0;
}

.template-mini-scroll {
  flex: 1;
}

.template-mini-list {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  width: max-content;
}

.template-mini-item {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  border: 2rpx solid transparent;
}

.template-mini-item.active {
  border-color: #3D2B1F;
}

.template-mini-name {
  font-size: 24rpx;
  color: #3D2B1F;
  font-family: serif;
}

/* ---- 成功状态 ---- */
.success-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  gap: 24rpx;
}

.success-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: rgba(61, 43, 31, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.success-icon {
  font-size: 56rpx;
  color: #3D2B1F;
  font-family: serif;
}

.success-title {
  font-size: 40rpx;
  color: #3D2B1F;
  font-family: serif;
  font-weight: 500;
  letter-spacing: 0.1em;
}

.success-sub {
  font-size: 26rpx;
  color: #9E9488;
  text-align: center;
  line-height: 1.6;
}

.success-actions {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
  margin-top: 24rpx;
}

.success-btn {
  padding: 20rpx 48rpx;
  border-radius: 48rpx;
  font-size: 28rpx;
  font-family: serif;
}

.success-btn.primary {
  background-color: #3D2B1F;
  color: #FAF7F2;
}

.success-btn.secondary {
  background-color: rgba(61, 43, 31, 0.1);
  color: #3D2B1F;
}

/* ---- 离屏Canvas（不可见） ---- */
.offscreen-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  opacity: 0;
  pointer-events: none;
}
