/* pages/wujuan/wujuan.wxss */

.page-root {
  width: 100%;
  height: 100vh;
  background-color: #F5F0E8;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ---- 顶部标题 ---- */
.header {
  padding: 20rpx 40rpx 20rpx;
  background-color: #F5F0E8;
  flex-shrink: 0;
}

.header-title {
  display: block;
  font-size: 44rpx;
  color: #3D2B1F;
  font-family: serif;
  font-weight: 500;
  letter-spacing: 0.08em;
}

.header-sub {
  display: block;
  font-size: 24rpx;
  color: #9E9488;
  margin-top: 6rpx;
}

/* ---- 标签栏 ---- */
.tabs {
  display: flex;
  flex-direction: row;
  padding: 0 40rpx;
  gap: 40rpx;
  border-bottom: 1rpx solid rgba(158, 148, 136, 0.2);
  flex-shrink: 0;
}

.tab-item {
  padding: 20rpx 0 16rpx;
  position: relative;
}

.tab-text {
  font-size: 28rpx;
  color: #9E9488;
  font-family: serif;
}

.tab-item.active .tab-text {
  color: #3D2B1F;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background-color: #3D2B1F;
  border-radius: 2rpx;
}

/* ---- 标签内容区 ---- */
.tab-content {
  flex: 1;
  overflow-y: auto;
}

/* ---- 空状态 ---- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  gap: 20rpx;
}

.empty-icon {
  font-size: 80rpx;
  color: rgba(158, 148, 136, 0.35);
  font-family: serif;
}

.empty-text {
  font-size: 32rpx;
  color: #9E9488;
  font-family: serif;
}

.empty-sub {
  font-size: 24rpx;
  color: rgba(158, 148, 136, 0.7);
  text-align: center;
  line-height: 1.6;
}

/* ---- 历史列表 ---- */
.history-list {
  padding: 16rpx 32rpx;
}

.history-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(158, 148, 136, 0.15);
}

.history-item:last-child {
  border-bottom: none;
}

.history-thumb {
  width: 80rpx;
  height: 106rpx;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.10);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.history-thumb-img {
  width: 100%;
  height: 100%;
}

.history-thumb-placeholder {
  font-size: 32rpx;
  color: rgba(61, 43, 31, 0.25);
  font-family: serif;
}

.history-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}

.history-text {
  font-size: 26rpx;
  color: #3D2B1F;
  font-family: serif;
  line-height: 1.6;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.history-meta {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  align-items: center;
}

.history-template {
  font-size: 22rpx;
  color: #9E9488;
  background-color: rgba(158, 148, 136, 0.12);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.history-date {
  font-size: 22rpx;
  color: #9E9488;
}

.history-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.delete-icon {
  font-size: 28rpx;
  color: rgba(158, 148, 136, 0.5);
}

/* ---- 模板网格 ---- */
.section-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 16rpx;
}

.section-title {
  font-size: 26rpx;
  color: #9E9488;
  letter-spacing: 0.05em;
}

.section-count {
  font-size: 22rpx;
  color: #9E9488;
}

.template-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  padding: 0 32rpx 32rpx;
}

.template-grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
}

.template-grid-item.active {
  border-color: #3D2B1F;
  background-color: rgba(61, 43, 31, 0.04);
}

.template-preview {
  width: 100%;
  aspect-ratio: 3/4;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.10);
  display: flex;
  align-items: center;
  justify-content: center;
}

.template-preview-text {
  font-size: 28rpx;
  font-family: serif;
  opacity: 0.5;
}

.template-grid-name {
  font-size: 22rpx;
  color: #3D2B1F;
  font-family: serif;
}

.template-grid-desc {
  font-size: 18rpx;
  color: #9E9488;
  text-align: center;
  line-height: 1.4;
}

/* 自定义模板占位 */
.custom-placeholder {
  padding: 40rpx;
  text-align: center;
}

.custom-hint {
  font-size: 24rpx;
  color: rgba(158, 148, 136, 0.6);
}

/* ---- 设置列表 ---- */
.settings-list {
  padding: 16rpx 32rpx;
}

.setting-section-title {
  font-size: 22rpx;
  color: #9E9488;
  letter-spacing: 0.05em;
  padding: 32rpx 0 12rpx;
  text-transform: uppercase;
}

.setting-item {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(158, 148, 136, 0.15);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.setting-label {
  font-size: 28rpx;
  color: #3D2B1F;
  font-family: serif;
}

.setting-desc {
  font-size: 22rpx;
  color: #9E9488;
}

.setting-value {
  font-size: 26rpx;
  color: #9E9488;
}

.setting-arrow {
  font-size: 24rpx;
  color: #9E9488;
}
