.page-root {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #FAF7F2;
  overflow: hidden;
}

/* ===== 顶部固定区域 ===== */
.top-area {
  flex-shrink: 0;
  background-color: #FAF7F2;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid rgba(158, 148, 136, 0.1);
}

/* ===== 搜索栏 ===== */
.search-bar {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx 8rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  height: 64rpx;
  background-color: rgba(255, 255, 255, 0.85);
  border-radius: 32rpx;
  border: 1rpx solid rgba(158, 148, 136, 0.2);
  padding: 0 20rpx;
}

.search-icon {
  font-size: 22rpx;
  color: rgba(107, 91, 79, 0.5);
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #3D2B1F;
  height: 40rpx;
}

.search-placeholder {
  color: rgba(158, 148, 136, 0.5);
  font-size: 26rpx;
}

.search-clear {
  font-size: 24rpx;
  color: rgba(158, 148, 136, 0.6);
  padding: 8rpx;
  flex-shrink: 0;
}

/* ===== 分类Tab ===== */
.category-scroll {
  flex-shrink: 0;
  white-space: nowrap;
  padding: 8rpx 0 6rpx;
}

.category-list {
  display: inline-flex;
  gap: 12rpx;
  padding: 0 24rpx;
}

.category-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
  color: #6B5B4F;
  background-color: rgba(255, 255, 255, 0.7);
  border-radius: 28rpx;
  border: 1rpx solid rgba(158, 148, 136, 0.18);
  transition: all 0.25s ease;
  white-space: nowrap;
}

.category-item.active {
  background-color: #6B5B4F;
  color: #FFFFFF;
  border-color: #6B5B4F;
}

/* ===== 标签筛选 ===== */
.tags-bar {
  flex-shrink: 0;
  padding: 4rpx 0 6rpx;
}

.tags-scroll {
  white-space: nowrap;
}

.tags-list {
  display: inline-flex;
  gap: 10rpx;
  padding: 0 24rpx;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx 14rpx;
  font-size: 18rpx;
  color: #6B5B4F;
  background-color: rgba(255, 255, 255, 0.65);
  border-radius: 16rpx;
  border: 1rpx solid rgba(158, 148, 136, 0.15);
  transition: all 0.2s ease;
  white-space: nowrap;
}

.tag-item.active {
  background-color: rgba(107, 91, 79, 0.1);
  color: #3D2B1F;
  border-color: rgba(107, 91, 79, 0.3);
  font-weight: 600;
}

/* ===== 结果统计 ===== */
.result-info {
  flex-shrink: 0;
  padding: 6rpx 24rpx 0;
  font-size: 20rpx;
  color: rgba(107, 91, 79, 0.45);
  line-height: 1.4;
}

/* ===== 内容列表 ===== */
.content-scroll {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.content-list {
  padding: 12rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
}

/* ===== 内容卡片 ===== */
.content-card {
  margin-bottom: 20rpx;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(61, 43, 31, 0.06);
  overflow: hidden;
}

.card-header {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  padding: 24rpx 24rpx 12rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3D2B1F;
  line-height: 1.4;
}

.card-dynasty {
  font-size: 22rpx;
  color: rgba(107, 91, 79, 0.55);
  flex-shrink: 0;
}

.card-author {
  font-size: 22rpx;
  color: #6B5B4F;
  flex-shrink: 0;
}

.card-body {
  padding: 8rpx 24rpx 20rpx;
}

.card-content {
  font-size: 28rpx;
  color: #3D2B1F;
  line-height: 1.8;
  letter-spacing: 1rpx;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  padding: 0 24rpx 16rpx;
}

.card-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx 14rpx;
  font-size: 18rpx;
  color: #6B5B4F;
  background-color: rgba(158, 148, 136, 0.1);
  border-radius: 16rpx;
  white-space: nowrap;
}

/* ===== 操作按钮 ===== */
.card-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 12rpx 24rpx 20rpx;
  border-top: 1rpx solid rgba(158, 148, 136, 0.1);
}

.action-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #6B5B4F;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 28rpx;
  border: 1rpx solid rgba(158, 148, 136, 0.2);
  transition: all 0.2s ease;
}

.action-btn:active {
  background-color: rgba(158, 148, 136, 0.15);
}

.copy-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #6B5B4F;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 28rpx;
  border: 1rpx solid rgba(158, 148, 136, 0.2);
  transition: all 0.2s ease;
}

.copy-btn:active {
  background-color: rgba(158, 148, 136, 0.15);
}

.luomo-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 28rpx;
  font-size: 24rpx;
  color: #FAF7F2;
  background-color: #6B5B4F;
  border-radius: 28rpx;
  border: none;
  transition: all 0.2s ease;
}

.luomo-btn:active {
  opacity: 0.85;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  gap: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: rgba(107, 91, 79, 0.45);
  letter-spacing: 4rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: rgba(158, 148, 136, 0.5);
  letter-spacing: 2rpx;
}
