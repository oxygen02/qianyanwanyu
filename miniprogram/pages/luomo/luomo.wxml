<!-- pages/luomo/luomo.wxml -->
<view class="page-root">

  <!-- 全屏编辑遮罩（输入框全屏，彻底覆盖底层 Canvas 原生组件） -->
  <view class="fullscreen-edit-overlay" wx:if="{{editModeFullscreen}}" style="background-color: #FFFFFF;">
    <view class="fullscreen-header" style="background-color: #FFFFFF;">
      <text class="fs-title">编辑文字</text>
    </view>
    <textarea class="fullscreen-textarea" id="fullscreenTextarea" model:value="{{text}}" placeholder="在此输入文字..."
      placeholder-class="input-placeholder" auto-height="{{false}}" fixed="{{true}}"
      show-confirm-bar="{{false}}" adjust-position="{{false}}" hold-keyboard="{{true}}"
      focus="{{fullscreenFocused}}"
      bindinput="onTextInput" bindfocus="onFullscreenInputFocus" bindblur="onFullscreenInputBlur"
      maxlength="{{-1}}" cursor-spacing="60"
      cursor="{{cursorPos}}" selection-start="{{selectionStart}}" selection-end="{{selectionEnd}}"
      style="height: {{fullscreenTextareaHeight}}px;"/>
    <view class="fullscreen-footer" style="background-color: #FFFFFF;">
      <text class="fs-char-count">{{text.length}} 字</text>
      <view class="fs-btn-group">
        <text class="fs-btn fs-btn--exit" bindtap="toggleEditMode">退出</text>
        <text class="fs-btn" bindtap="onSelectAllText" wx:if="{{text.length > 0}}">全选</text>
        <text class="fs-btn" bindtap="onCopyText" wx:if="{{text.length > 0}}">复制</text>
        <text class="fs-btn fs-btn--clear" bindtap="onClearDraft">清空</text>
        <text class="fs-btn fs-btn--done" bindtap="toggleEditMode">完成</text>
      </view>
    </view>
  </view>

  <!-- 书页展示区（全屏编辑时彻底隐藏，避免原生 Canvas 穿透 overlay） -->
  <view class="canvas-area" wx:if="{{!editModeFullscreen}}" style="padding-top: calc(6rpx + {{safeAreaTop}}px); {{canvasAreaStyle}}">
    <view class="page-dots" wx:if="{{totalPages > 1 && !settingsPanelVisible && !editModeFullscreen}}">
      <view wx:for="{{pageDots}}" wx:key="index" class="page-dot {{currentPage === index ? 'active' : ''}}"/>
    </view>

    <view class="canvas-wrapper">
      <canvas id="bookCanvas" type="2d" class="book-canvas {{canvasZoomed ? 'zoomed' : ''}}"
        bindtouchstart="onCanvasTouchStart" bindtouchend="onCanvasTouchEnd"/>
    </view>

    <view class="loading-mask" wx:if="{{isRendering}}">
      <view class="loading-dot-wrap">
        <view class="loading-dot d1"/><view class="loading-dot d2"/><view class="loading-dot d3"/>
      </view>
    </view>

    <!-- 等待界面：字体加载 + 诗词展示（合二为一，不重叠） -->
    <view class="waiting-overlay" wx:if="{{showWaitingPoem || fontLoadingVisible}}">
      <view class="loading-status" wx:if="{{fontLoadingVisible}}">
        <view class="font-loading-spinner"></view>
        <text class="loading-text">{{fontLoading ? '正在准备字体...' : '准备就绪'}}</text>
        <view class="loading-progress-bar" wx:if="{{fontLoading}}">
          <view class="progress-fill" style="width: {{fontLoadingPercent}}%"></view>
        </view>
      </view>

      <view class="poem-card" wx:if="{{showWaitingPoem && waitingPoem}}">
        <text class="poem-title">{{waitingPoem.title}}</text>
        <text class="poem-author">—— {{waitingPoem.dynasty || ''}}{{waitingPoem.author}}</text>
        <view class="poem-divider"></view>
        <view class="poem-content typewriter">
          <text class="typewriter-line" wx:for="{{displayedLines}}" wx:key="index">{{item}}</text>
          <text class="typewriter-cursor" wx:if="{{!isTypingComplete}}">|</text>
        </view>
      </view>
    </view>

    <view class="empty-hint" wx:if="{{!text && !isRendering && !fontLoadingVisible && !showWaitingPoem}}">
      <text class="empty-text">为文字造一页纸</text>
      <text class="empty-sub">让阅读回到阅读</text>
    </view>
  </view>

  <!-- 底部区域 -->
  <view class="bottom-area" style="{{bottomAreaStyle}}" wx:if="{{!editModeFullscreen}}">
    <!-- 工具栏 - 嵌入底部区域顶端 -->
    <view class="toolbar-embedded">
      <view class="tb-btn {{settingsTab === 'text' && settingsPanelVisible ? 'tb-btn--on' : ''}}" bindtap="onToggleSettings" data-tab="text">
        <text class="tb-txt">文字</text>
      </view>
      <view class="tb-btn {{settingsTab === 'paper' && settingsPanelVisible ? 'tb-btn--on' : ''}}" bindtap="onToggleSettings" data-tab="paper">
        <text class="tb-txt">纸张</text>
      </view>
      <view class="tb-btn {{settingsTab === 'layout' && settingsPanelVisible ? 'tb-btn--on' : ''}}" bindtap="onToggleSettings" data-tab="layout">
        <text class="tb-txt">排版</text>
      </view>
      <view class="tb-btn tb-btn--save" bindtap="onExport">
        <text class="tb-txt">保存</text>
      </view>
    </view>

    <view class="input-area {{settingsPanelVisible ? 'input-area--hidden' : ''}}" style="height: {{inputAreaHeight}}px;">
      <textarea class="text-input" id="mainTextInput" model:value="{{text}}" placeholder="在此写下文字..."
        placeholder-class="input-placeholder" auto-height="{{false}}" fixed="{{true}}"
        show-confirm-bar="{{false}}" adjust-position="{{false}}" hold-keyboard="{{true}}"
        bindinput="onTextInput" bindfocus="onInputFocus" bindblur="onInputBlur"
        bindlongpress="onInputLongPress"
        maxlength="{{-1}}" cursor-spacing="25"
        cursor="{{cursorPos}}" selection-start="{{selectionStart}}" selection-end="{{selectionEnd}}"
        style="height: {{textInputHeight}}px;"/>
      <view class="input-toolbar">
        <view class="input-actions-left"><text class="char-count">{{text.length}} 字</text><text class="action-btn action-btn--small" bindtap="toggleEditMode">全屏编辑</text></view>
        <view class="input-actions-right"><text class="action-btn" bindtap="onClearDraft">清空</text></view>
      </view>
    </view>

    <view class="settings-panel {{settingsPanelVisible ? 'settings-panel--visible' : ''}}" wx:if="{{settingsPanelVisible}}">
      <scroll-view scroll-y class="settings-body" enhanced show-scrollbar="{{false}}">
        <block wx:if="{{settingsTab === 'text'}}">
          <view class="settings-content">
            <view class="settings-row">
              <view class="settings-cell">
                <view class="setting-label">字体</view>
                <picker mode="selector" range="{{textSettings.fontOptions}}" range-key="pickerLabel" bindchange="onTextFontChange" value="{{textSettings.fontIndex}}">
                  <view class="setting-value"><text class="value-text-mini">{{textSettings.fontOptions[textSettings.fontIndex].name}}</text><text class="arrow">›</text></view>
                </picker>
              </view>
              <view class="settings-cell">
                <view class="setting-label">字重</view>
                <picker mode="selector" range="{{textSettings.weightOptions}}" bindchange="onTextWeightChange" value="{{textSettings.weightIndex}}">
                  <view class="setting-value"><text class="value-text-mini">{{textSettings.weightOptions[textSettings.weightIndex]}}</text><text class="arrow">›</text></view>
                </picker>
              </view>
              <view class="settings-cell">
                <view class="setting-label">墨色</view>
                <picker mode="selector" range="{{textSettings.inkColorOptions}}" range-key="name" bindchange="onTextInkColorChange" value="{{textSettings.inkColorIndex}}">
                  <view class="setting-value"><text class="value-text-mini">{{textSettings.inkColorOptions[textSettings.inkColorIndex].name}}</text><text class="arrow">›</text></view>
                </picker>
              </view>
              <view class="settings-cell settings-cell-align">
                <view class="setting-label">对齐</view>
                <view class="align-options">
                  <view class="align-option {{textSettings.textAlign === 'left' ? 'active' : ''}}" bindtap="onTextAlignTap" data-align="left"><text>左</text></view>
                  <view class="align-option {{textSettings.textAlign === 'center' ? 'active' : ''}}" bindtap="onTextAlignTap" data-align="center"><text>中</text></view>
                </view>
              </view>
            </view>
            <view class="settings-row">
              <view class="settings-cell settings-cell-switch"><view class="setting-label">品牌印</view><switch checked="{{textSettings.brandStampEnabled}}" bindchange="onBrandStampToggle" color="#6B5B4F" style="transform: scale(0.6); transform-origin: right center;"/></view>
              <view class="settings-cell settings-cell-switch"><view class="setting-label">繁简</view><switch checked="{{textSettings.traditionalChinese}}" bindchange="onTraditionalChineseToggle" color="#6B5B4F" style="transform: scale(0.6); transform-origin: right center;"/></view>
              <view class="settings-cell settings-cell-switch"><view class="setting-label">描边</view><switch checked="{{textSettings.strokeEnabled}}" bindchange="onStrokeToggle" color="#6B5B4F" style="transform: scale(0.6); transform-origin: right center;"/></view>
              <view class="settings-cell settings-cell-switch"><view class="setting-label">换行</view><switch checked="{{textSettings.preserveLineBreaks}}" bindchange="onLineBreakToggle" color="#6B5B4F" style="transform: scale(0.6); transform-origin: right center;"/></view>
            </view>
            <view class="settings-row">
              <view class="settings-cell"><view class="setting-label">字号</view><view class="setting-value"><slider class="slider-mini" min="20" max="60" step="1" value="{{textSettings.fontSize}}" activeColor="#6B5B4F" backgroundColor="rgba(158,148,136,0.2)" block-size="16" bindchange="onFontSizeChange"/><text class="slider-value-mini">{{textSettings.fontSize}}px</text></view></view>
              <view class="settings-cell"><view class="setting-label">深浅</view><view class="setting-value"><slider class="slider-mini" min="10" max="100" step="5" value="{{textSettings.inkOpacity}}" activeColor="#6B5B4F" backgroundColor="rgba(158,148,136,0.2)" block-size="20" bindchange="onTextInkOpacityChange"/><text class="slider-value-mini">{{textSettings.inkOpacity}}%</text></view></view>
              <view class="settings-cell"><view class="setting-label">倾斜</view><view class="setting-value"><slider class="slider-mini" min="-10" max="10" step="1" value="{{textSettings.textSkew}}" activeColor="#6B5B4F" backgroundColor="rgba(158,148,136,0.2)" block-size="20" bindchange="onTextSkewChange"/><text class="slider-value-mini">{{textSettings.textSkewDisplay}}</text></view></view>
            </view>
            <view class="settings-row" wx:if="{{textSettings.strokeEnabled}}">
              <view class="settings-cell settings-cell--wide"><view class="setting-label">描边粗细</view><view class="setting-value"><slider class="slider-mini" min="0" max="10" step="0.5" value="{{textSettings.strokeWidth}}" activeColor="#6B5B4F" backgroundColor="rgba(158,148,136,0.2)" block-size="20" bindchange="onStrokeWidthChange"/><text class="slider-value-mini">{{textSettings.strokeWidth}}px</text></view></view>
            </view>
          </view>
        </block>

        <block wx:if="{{settingsTab === 'paper'}}">
          <view class="settings-content">
            <view class="settings-row settings-row--four">
              <view class="settings-cell settings-cell--margin" bindtap="onTogglePaperTemplates"><view class="setting-label">纸张模板</view><view class="setting-value"><text class="value-text-mini">{{paperSettings.templateOptions[paperSettings.templateIndex].name}}</text><text class="arrow">{{paperSettings.templateExpanded ? '‹' : '›'}}</text></view></view>
              <view class="settings-cell settings-cell--fourth"><view class="setting-label">底色</view><picker mode="selector" range="{{paperSettings.colorOptions}}" range-key="name" bindchange="onPaperColorChange" value="{{paperSettings.colorIndex}}"><view class="setting-value"><text class="value-text-mini">{{paperSettings.colorOptions[paperSettings.colorIndex].name}}</text><text class="arrow">›</text></view></picker></view>
              <view class="settings-cell settings-cell--fourth"><view class="setting-label">老旧度</view><picker mode="selector" range="{{paperSettings.agingOptions}}" bindchange="onPaperAgingChange" value="{{paperSettings.agingIndex}}"><view class="setting-value"><text class="value-text-mini">{{paperSettings.agingOptions[paperSettings.agingIndex]}}</text><text class="arrow">›</text></view></picker></view>
              <view class="settings-cell settings-cell--fourth"><view class="setting-label">纹理</view><picker mode="selector" range="{{paperSettings.textureOptions}}" bindchange="onPaperTextureChange" value="{{paperSettings.textureIndex}}"><view class="setting-value"><text class="value-text-mini">{{paperSettings.textureOptions[paperSettings.textureIndex]}}</text><text class="arrow">›</text></view></picker></view>
            </view>
            <view wx:if="{{paperSettings.templateExpanded}}" style="padding:16rpx 0;background:#FAF7F2;border-top:1rpx solid rgba(158,148,136,0.2);margin-bottom:8rpx;">
              <scroll-view scroll-x style="width:100%;white-space:nowrap;"><view style="display:inline-flex;padding:0 16rpx;gap:12rpx;">
                <view wx:for="{{paperSettings.templateOptions}}" wx:key="id" style="display:flex;flex-direction:column;align-items:center;width:100rpx;flex-shrink:0;" bindtap="onPaperTemplateChangeDirect" data-index="{{index}}">
                  <view style="width:100rpx;height:120rpx;border-radius:6rpx;border:1rpx solid #DDD;margin-bottom:6rpx;background-color:{{item.paperColor}};position:relative;box-shadow:0 2rpx 6rpx rgba(0,0,0,0.08);">
                    <text wx:if="{{item.watermarkText}}" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);font-size:24rpx;color:rgba(0,0,0,0.15)">{{item.watermarkText}}</text>
                  </view>
                  <text style="font-size:18rpx;color:#6B5B4F;text-align:center;">{{item.name}}</text>
                </view>
              </view></scroll-view>
            </view>
            <view class="settings-row settings-row--four">
              <view class="settings-cell settings-cell--margin"><view class="setting-label">上下边距</view><view class="setting-value"><slider class="slider-mini" min="5" max="80" step="1" value="{{paperSettings.marginVertical}}" activeColor="#6B5B4F" backgroundColor="rgba(158,148,136,0.2)" block-size="20" bindchange="onPaperMarginVerticalChange"/><text class="slider-value-mini">{{paperSettings.marginVertical}}</text></view></view>
              <view class="settings-cell settings-cell-switch settings-cell--fourth"><view class="setting-label">阴影</view><switch checked="{{paperSettings.shadowEnabled}}" bindchange="onPaperShadowToggle" color="#6B5B4F" style="transform: scale(0.6); transform-origin: right center;"/></view>
              <view class="settings-cell settings-cell-switch settings-cell--fourth"><view class="setting-label">瑕疵</view><switch checked="{{paperSettings.imperfectionEnabled}}" bindchange="onPaperImperfectionToggle" color="#6B5B4F" style="transform: scale(0.6); transform-origin: right center;"/></view>
              <view class="settings-cell settings-cell-switch settings-cell--fourth"><view class="setting-label">装订</view><switch checked="{{paperSettings.stitchEnabled}}" bindchange="onPaperStitchToggle" color="#6B5B4F" style="transform: scale(0.6); transform-origin: right center;"/></view>
            </view>
            <view class="settings-row settings-row--four">
              <view class="settings-cell settings-cell--margin"><view class="setting-label">左右边距</view><view class="setting-value"><slider class="slider-mini" min="0" max="80" step="1" value="{{paperSettings.marginHorizontal}}" activeColor="#6B5B4F" backgroundColor="rgba(158,148,136,0.2)" block-size="20" bindchange="onPaperMarginHorizontalChange"/><text class="slider-value-mini">{{paperSettings.marginHorizontal}}</text></view></view>
              <view class="settings-cell settings-cell--fourth"><view class="setting-label">卷边</view><picker mode="selector" range="{{paperSettings.curlOptions}}" bindchange="onPaperCurlChange" value="{{paperSettings.curlIndex}}"><view class="setting-value"><text class="value-text-mini">{{paperSettings.curlOptions[paperSettings.curlIndex]}}</text><text class="arrow">›</text></view></picker></view>
              <view class="settings-cell settings-cell--fourth"><view class="setting-label">撕边</view><picker mode="selector" range="{{paperSettings.tearOptions}}" bindchange="onPaperTearChange" value="{{paperSettings.tearIndex}}"><view class="setting-value"><text class="value-text-mini">{{paperSettings.tearOptions[paperSettings.tearIndex]}}</text><text class="arrow">›</text></view></picker></view>
              <view class="settings-cell settings-cell--fourth"><view class="setting-label">尺寸</view><picker mode="selector" range="{{paperSettings.sizeOptions}}" bindchange="onPaperSizeChange" value="{{paperSettings.sizeIndex}}"><view class="setting-value"><text class="value-text-mini">{{paperSettings.sizeOptions[paperSettings.sizeIndex]}}</text><text class="arrow">›</text></view></picker></view>
            </view>
          </view>
        </block>

        <block wx:if="{{settingsTab === 'layout'}}">
          <view class="settings-content">
            <view class="settings-row settings-row--four">
              <view class="settings-cell settings-cell--fourth"><view class="setting-label">文字方向</view><picker mode="selector" range="{{layoutSettings.directionOptions}}" bindchange="onLayoutDirectionChange" value="{{layoutSettings.directionIndex}}"><view class="setting-value"><text class="value-text-mini">{{layoutSettings.directionOptions[layoutSettings.directionIndex]}}</text><text class="arrow">›</text></view></picker></view>
              <view class="settings-cell settings-cell--fourth"><view class="setting-label">首行缩进</view><picker mode="selector" range="{{layoutSettings.indentOptions}}" bindchange="onLayoutIndentChange" value="{{layoutSettings.indentIndex}}"><view class="setting-value"><text class="value-text-mini">{{layoutSettings.indentOptions[layoutSettings.indentIndex]}}</text><text class="arrow">›</text></view></picker></view>
              <view class="settings-cell settings-cell--fourth settings-cell-switch"><view class="setting-label">页眉页脚</view><switch checked="{{layoutSettings.headerFooterEnabled}}" bindchange="onLayoutHeaderFooterToggle" color="#6B5B4F" style="transform: scale(0.6); transform-origin: right center;"/></view>
              <view class="settings-cell settings-cell--fourth settings-cell-switch"><view class="setting-label">页码显示</view><switch checked="{{layoutSettings.pageNumberEnabled}}" bindchange="onLayoutPageNumberToggle" color="#6B5B4F" style="transform: scale(0.6); transform-origin: right center;"/></view>
            </view>
            <view class="settings-row settings-row--four">
              <view class="settings-cell settings-cell--fourth"><view class="setting-label">行间距</view><view class="setting-value"><slider class="slider-mini" min="60" max="240" step="1" value="{{layoutSettings.lineHeight}}" activeColor="#6B5B4F" backgroundColor="rgba(158,148,136,0.2)" block-size="20" bindchange="onLayoutLineHeightChange"/><text class="slider-value-mini">{{layoutSettings.lineHeightDisplay}}</text></view></view>
              <view class="settings-cell settings-cell--fourth"><view class="setting-label">字间距</view><view class="setting-value"><slider class="slider-mini" min="0" max="30" step="1" value="{{layoutSettings.letterSpacing}}" activeColor="#6B5B4F" backgroundColor="rgba(158,148,136,0.2)" block-size="20" bindchange="onLayoutLetterSpacingChange"/><text class="slider-value-mini">{{layoutSettings.letterSpacing}}%</text></view></view>
              <view class="settings-cell settings-cell--fourth"><view class="setting-label">段落间距</view><view class="setting-value"><slider class="slider-mini" min="0" max="80" step="2" value="{{layoutSettings.paragraphSpacing}}" activeColor="#6B5B4F" backgroundColor="rgba(158,148,136,0.2)" block-size="20" bindchange="onLayoutParagraphSpacingChange"/><text class="slider-value-mini">{{layoutSettings.paragraphSpacing}}</text></view></view>
              <view class="settings-cell settings-cell--fourth"><view class="setting-label">排版松紧</view><view class="setting-value"><slider class="slider-mini" min="0" max="100" step="5" value="{{layoutSettings.compactness}}" activeColor="#6B5B4F" backgroundColor="rgba(158,148,136,0.2)" block-size="20" bindchange="onLayoutCompactnessChange"/><text class="slider-value-mini">{{layoutSettings.compactness}}%</text></view></view>
            </view>
            <view class="settings-row settings-row--four">
              <view class="settings-cell settings-cell--fourth settings-cell-switch"><view class="setting-label">字体风化</view><switch checked="{{layoutSettings.weatheringEnabled}}" bindchange="onLayoutWeatheringToggle" color="#6B5B4F" style="transform: scale(0.6); transform-origin: right center;"/></view>
              <view class="settings-cell settings-cell--fourth settings-cell-switch"><view class="setting-label">墨色浸染</view><switch checked="{{layoutSettings.inkSpreadEnabled}}" bindchange="onLayoutInkSpreadToggle" color="#6B5B4F" style="transform: scale(0.6); transform-origin: right center;"/></view>
              <view class="settings-cell settings-cell--fourth settings-cell-switch"><view class="setting-label">套印错位</view><switch checked="{{layoutSettings.misregistrationEnabled}}" bindchange="onLayoutMisregistrationToggle" color="#6B5B4F" style="transform: scale(0.6); transform-origin: right center;"/></view>
              <view class="settings-cell settings-cell--fourth settings-cell-switch"><view class="setting-label">页面破损</view><switch checked="{{layoutSettings.damageEnabled}}" bindchange="onLayoutDamageToggle" color="#6B5B4F" style="transform: scale(0.6); transform-origin: right center;"/></view>
            </view>
            <view class="settings-row" wx:if="{{layoutSettings.weatheringEnabled}}">
              <view class="settings-cell"><view class="setting-label">风化强度</view><view class="setting-value"><slider class="slider-mini" min="0" max="100" step="5" value="{{layoutSettings.weatheringIntensity}}" activeColor="#6B5B4F" backgroundColor="rgba(158,148,136,0.2)" block-size="20" bindchange="onLayoutWeatheringIntensityChange"/><text class="slider-value-mini">{{layoutSettings.weatheringIntensity}}%</text></view></view>
            </view>
            <view class="settings-row" wx:if="{{layoutSettings.inkSpreadEnabled}}">
              <view class="settings-cell"><view class="setting-label">浸染强度</view><view class="setting-value"><slider class="slider-mini" min="0" max="100" step="5" value="{{layoutSettings.inkSpreadIntensity}}" activeColor="#6B5B4F" backgroundColor="rgba(158,148,136,0.2)" block-size="20" bindchange="onLayoutInkSpreadIntensityChange"/><text class="slider-value-mini">{{layoutSettings.inkSpreadIntensity}}%</text></view></view>
            </view>
            <view class="settings-row" wx:if="{{layoutSettings.misregistrationEnabled}}">
              <view class="settings-cell"><view class="setting-label">错位偏移</view><view class="setting-value"><slider class="slider-mini" min="0" max="10" step="1" value="{{layoutSettings.misregistrationOffset}}" activeColor="#6B5B4F" backgroundColor="rgba(158,148,136,0.2)" block-size="20" bindchange="onLayoutMisregistrationOffsetChange"/><text class="slider-value-mini">{{layoutSettings.misregistrationOffset}}</text></view></view>
            </view>
            <view class="settings-row" wx:if="{{layoutSettings.damageEnabled}}">
              <view class="settings-cell"><view class="setting-label">破损程度</view><view class="setting-value"><slider class="slider-mini" min="0" max="20" step="1" value="{{settings.damageVal}}" activeColor="#6B5B4F" backgroundColor="rgba(158,148,136,0.2)" block-size="20" bindchange="onDamageChange"/><text class="slider-value-mini">{{settings.damageVal}}</text></view></view>
            </view>
          </view>
        </block>
      </scroll-view>
    </view>
  </view>

  <view class="font-panel {{fontPanelVisible ? 'font-panel--visible' : ''}}" wx:if="{{fontPanelVisible}}" bindtap="onCloseFontPanelBg">
    <view class="font-panel-content" catchtap="_stopProp">
      <view class="font-panel-header">
        <text class="font-panel-back" bindtap="onCloseFontPanel">‹ 返回</text>
        <text class="font-panel-title">选择字体</text>
        <text class="font-panel-close" bindtap="onCloseFontPanel">✕</text>
      </view>
      <view class="font-tip"><text class="font-tip-text">字体下载需消耗流量，建议在Wi-Fi环境下下载</text></view>
      <scroll-view scroll-y class="font-grid">
        <view class="font-grid-inner">
          <view wx:for="{{fontList}}" wx:key="index" class="font-grid-item {{activeFontId === item.id ? 'active' : ''}}" bindtap="onSelectFont" data-id="{{item.id}}" data-font="{{item.family}}">
            <view class="font-main"><text class="font-name">{{item.name}}</text></view>
            <view class="font-meta">
              <text class="font-size" wx:if="{{item.fileSizeLabel}}">{{item.fileSizeLabel}}</text>
              <text class="font-status-tag {{item.isLoaded ? 'loaded' : ''}}" wx:if="{{item.isLoaded !== undefined}}">{{item.isLoaded ? '✓ 已缓存' : '待下载'}}</text>
            </view>
            <view class="font-check" wx:if="{{activeFontId === item.id}}">✓</view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="template-panel {{templatePanelVisible ? 'template-panel--visible' : ''}}" wx:if="{{templatePanelVisible}}" bindtap="onCloseTemplatesBg">
    <view class="template-panel-content" catchtap="_stopProp">
      <view class="template-panel-header">
        <text class="template-panel-title">选择模板</text>
        <text class="template-panel-close" bindtap="onCloseTemplates">✕</text>
      </view>
      <scroll-view scroll-y class="template-grid">
        <view class="template-grid-inner">
          <view wx:for="{{templateList}}" wx:key="index" class="template-grid-item {{activeTemplateId === item.id ? 'active' : ''}}" bindtap="onSelectTemplate" data-id="{{item.id}}">
            <view class="template-preview" wx:if="{{item.paper && item.paper.backgroundImage}}"><image class="template-preview-img" src="{{item.paper.backgroundImage.fileID}}" mode="aspectFill"></image></view>
            <view class="template-info"><text class="template-name">{{item.name}}</text></view>
            <view class="template-check" wx:if="{{activeTemplateId === item.id}}">✓</view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="save-panel {{savePanelVisible ? 'save-panel--visible' : ''}}" wx:if="{{savePanelVisible}}" bindtap="onCloseSavePanelBg">
    <view class="save-panel-content" catchtap="_stopProp">
      <view class="save-panel-header">
        <text class="save-panel-title">保存作品</text>
        <text class="save-panel-close" bindtap="onCloseSavePanel">✕</text>
      </view>
      <view class="save-options">
        <view class="save-option" bindtap="onSaveToAlbum"><text class="save-option-label">保存到相册</text></view>
        <view class="save-option" bindtap="onShareToFriends"><text class="save-option-label">分享给好友</text></view>
      </view>
    </view>
  </view>
</view>
