/* 单元格：纵向布局，label在上，controls在下 */
/* slider等控件在纵向单元格中获取完整宽度，便于手指操作 */
.settings-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  padding: 6rpx 12rpx;
  background: rgba(255, 255, 255, 0.65);
  border-radius: 6rpx;
  border: 1rpx solid rgba(158, 148, 136, 0.1);
  min-width: 0;
  overflow: visible;
  box-sizing: border-box;
}

.settings-cell-full {
  flex: 1;
  width: 100%;
}

/* 宽/窄单元格比例 */
.settings-cell--wide {
  flex: 2.2;
  min-width: 200rpx;
  padding: 6rpx 12rpx;
  box-sizing: border-box;
}

.settings-cell--narrow {
  flex: 0.7;
  padding: 8rpx 12rpx;
  box-sizing: border-box;
  background: rgba(255, 255, 255, 0.65);
  border-radius: 6rpx;
  border: 1rpx solid rgba(158, 148, 136, 0.1);
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* 紧凑堆叠cell（如卷撕边的双picker） */
.settings-cell--compact .setting-label {
  font-size: 20rpx;
}

.settings-cell--compact .value-text-mini {
  font-size: 20rpx;
}

.settings-cell--compact .arrow {
  font-size: 28rpx;
}

/* 水平双picker容器 */
.setting-value-h {
  display: flex;
  flex-direction: row;
  gap: 4rpx;
  flex: 1;
  min-width: 0;
}

.setting-value-h picker {
  flex: 1;
  min-width: 0;
}

.setting-value-h .setting-value {
  gap: 2rpx;
}

.setting-value-h .value-text-mini {
  font-size: 20rpx;
}

.setting-value-h .arrow {
  font-size: 28rpx;
}

.settings-cell-switch {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 28rpx 8rpx 12rpx;
  min-width: 0;
  flex: 1;
  min-height: 64rpx;
  position: relative;
  background: rgba(255, 255, 255, 0.65);
  border-radius: 6rpx;
  border: 1rpx solid rgba(158, 148, 136, 0.1);
  box-sizing: border-box;
}

.settings-cell-switch switch {
  margin-left: -20rpx;
  transform: scale(0.55);
  transform-origin: right center;
}

/* 横向布局cell：label和控件左右排列 */
.settings-cell-h {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 12rpx;
  min-width: 0;
  flex: 1;
  min-height: 78rpx;
  max-height: 78rpx;
  background: rgba(255, 255, 255, 0.65);
  border-radius: 6rpx;
  border: 1rpx solid rgba(158, 148, 136, 0.1);
  box-sizing: border-box;
}

.settings-cell-h .setting-label {
  flex-shrink: 0;
}

.settings-cell-h .setting-value {
  flex: 1;
}

.setting-label {
  font-size: 17rpx;
  color: #3D2B1F;
  font-weight: 500;
  flex-shrink: 0;
  line-height: 1.2;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.setting-value {
  display: flex;
  align-items: center;
  gap: 0rpx;
  flex: 1;
  min-width: 0;
  min-height: 40rpx;
}

.setting-value .slider-mini {
  margin-right: -20rpx;
}

.setting-value .slider-value-mini {
  margin-left: -5rpx;
}

.value-text-mini {
  font-size: 17rpx;
  color: #6B5B4F;
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.4;
}

.font-size-hint {
  font-size: 14rpx;
  color: rgba(158, 148, 136, 0.7);
  flex-shrink: 0;
  margin-left: 6rpx;
  padding: 2rpx 8rpx;
  background-color: rgba(158, 148, 136, 0.08);
  border-radius: 4rpx;
  line-height: 1.4;
}

.font-status-badge {
  font-size: 12rpx;
  flex-shrink: 0;
  margin-left: 6rpx;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  line-height: 1.4;
  color: rgba(200, 80, 60, 0.85);
  background-color: rgba(200, 80, 60, 0.08);
}

.font-status-badge.loaded {
  color: rgba(80, 150, 100, 0.9);
  background-color: rgba(80, 150, 100, 0.1);
}

/* Picker 选择器 */
picker {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

picker .setting-value {
  flex: 1;
}

.size-toggle-mini {
  display: flex;
  background-color: rgba(158, 148, 136, 0.15);
  border-radius: 3rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.toggle-btn-mini {
  padding: 2rpx 8rpx;
  font-size: 20rpx;
  color: rgba(107, 91, 79, 0.6);
  font-weight: 500;
}

.toggle-btn-mini.active {
  background-color: #6B5B4F;
  color: #FAF7F2;
}

.slider-mini {
  flex: 1;
  min-width: 120rpx;
  margin: 0 4rpx;
  padding: 0;
  height: 36rpx;
  min-height: 36rpx;
}

.slider-value-mini {
  font-size: 17rpx;
  color: #6B5B4F;
  font-weight: 500;
  min-width: 56rpx;
  text-align: right;
  line-height: 1.4;
  padding-left: 8rpx;
}

.align-radio-mini,
.vertical-dir-radio-mini,
.empty-line-radio-mini {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  justify-content: flex-start;
  align-items: center;
  flex: 1;
  padding: 0rpx 4rpx;
  box-sizing: border-box;
  width: 100%;
  overflow: hidden;
}

.radio-label-mini {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-shrink: 0;
  gap: 12rpx;
  font-size: 18rpx;
  color: #6B5B4F;
  line-height: 1.4;
  padding: 0;
  white-space: nowrap;
  box-sizing: border-box;
  overflow: hidden;
}

.radio-label-mini radio {
  transform: scale(0.5);
  transform-origin: center center;
  margin: 0;
  padding: 0;
  margin-right: 0rpx;
}

.settings-cell .align-radio-mini {
  gap: 20rpx !important;
}

.settings-cell .align-radio-mini .radio-label-mini {
  gap: 10rpx !important;
  font-size: 18rpx !important;
}

.settings-cell-align {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 12rpx;
  box-sizing: border-box;
  min-height: 72rpx;
  justify-content: center;
}

.settings-cell-align .setting-label {
  font-size: 18rpx;
  color: #3D2B1F;
  font-weight: 500;
  margin-bottom: 8rpx;
  line-height: 1.4;
  height: 24rpx;
  display: flex;
  align-items: center;
}

.settings-cell-align .align-options {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 30rpx;
  width: 100%;
  height: 26rpx;
}

.settings-cell-align .align-option {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  background-color: rgba(158, 148, 136, 0.1);
  transition: all 0.2s;
}

.settings-cell-align .align-option.active {
  background-color: #6B5B4F;
}

.settings-cell-align .align-option.active text {
  color: #FAF7F2;
}

.settings-cell-align .align-option text {
  font-size: 18rpx;
  color: #6B5B4F;
}

.input-field-mini {
  flex: 1;
  height: 32rpx;
  padding: 0 8rpx;
  background-color: rgba(158, 148, 136, 0.1);
  border-radius: 4rpx;
  font-size: 22rpx;
  color: #3D2B1F;
  min-width: 0;
}

.poetry-mode-btn {
  width: 100%;
  background: linear-gradient(135deg, #6B5B4F, #9E9488);
  color: #FAF7F2;
  border: none;
  border-radius: 4rpx;
  padding: 6rpx 10rpx;
  font-size: 16rpx;
  font-weight: 500;
}

.poetry-mode-btn::after {
  border: none;
}

.reset-btn-container {
  padding: 4rpx 0 0;
}

.reset-btn {
  background-color: rgba(107, 91, 79, 0.1);
  color: #6B5B4F;
  border: none;
  border-radius: 4rpx;
  font-size: 16rpx;
  padding: 6rpx 12rpx;
}

.reset-btn::after {
  border: none;
}

/* ===== 新增设置页面样式 ===== */
.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 12rpx;
  background-color: rgba(255, 255, 255, 0.6);
  margin-bottom: 6rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(158, 148, 136, 0.1);
}

.setting-label {
  font-size: 16rpx;
  font-weight: 500;
  color: #3D2B1F;
}

.setting-value {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex: 1;
}

.value-text {
  font-size: 20rpx;
  color: #6B5B4F;
  margin-right: 4rpx;
}

.arrow {
  font-size: 28rpx;
  color: #9E9488;
  line-height: 1.2;
}

/* 字号切换 */
.size-toggle {
  display: flex;
  background-color: rgba(158, 148, 136, 0.15);
  border-radius: 4rpx;
  overflow: hidden;
  margin-right: 6rpx;
}

.toggle-btn {
  padding: 4rpx 10rpx;
  font-size: 15rpx;
  color: rgba(107, 91, 79, 0.6);
  font-weight: 500;
  transition: all 0.2s;
}

.toggle-btn.active {
  background-color: #6B5B4F;
  color: #FAF7F2;
}

/* Slider 样式 */
.size-slider,
.opacity-slider,
.shadow-slider,
.margin-slider,
.imperfection-slider,
.weathering-slider,
.ink-spread-slider,
.misregistration-slider,
.damage-slider,
.paragraph-spacing-slider,
.compactness-slider {
  flex: 1;
  max-width: 200rpx;
}

.line-height-slider,
.letter-spacing-slider,
.stroke-slider,
.skew-slider {
  flex: 1;
  max-width: 160rpx;
}

.size-display,
.opacity-display,
.shadow-display,
.margin-display,
.imperfection-display,
.weathering-display,
.ink-spread-display,
.misregistration-display,
.damage-display,
.paragraph-spacing-display,
.compactness-display,
.line-height-display,
.letter-spacing-display,
.stroke-display,
.skew-display {
  font-size: 20rpx;
  color: #6B5B4F;
  font-weight: 500;
  width: 56rpx;
  text-align: right;
}

/* Radio 样式 */
.align-radio,
.vertical-dir-radio,
.empty-line-radio {
  display: flex;
  gap: 12rpx;
}

.radio-label {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 22rpx;
  color: #6B5B4F;
}

/* 输入框样式 */
.input-field {
  flex: 1;
  height: 44rpx;
  padding: 0 10rpx;
  background-color: rgba(158, 148, 136, 0.1);
  border-radius: 6rpx;
  font-size: 15rpx;
  color: #3D2B1F;
}

/* 诗词模式按钮 */
.poetry-mode-btn {
  background: linear-gradient(135deg, #6B5B4F, #9E9488);
  color: #FAF7F2;
  border: none;
  border-radius: 6rpx;
  padding: 6rpx 16rpx;
  font-size: 15rpx;
  font-weight: 500;
}

