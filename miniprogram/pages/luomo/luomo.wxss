/* ========== 页面根容器 ========== */
.page-root {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F5F0E8;
  overflow: hidden;
  position: relative;
}

/* ========== 书页展示区（Canvas 区域）- 填充剩余高度，纸张效果 ========== */
.canvas-area {
  flex: 1;
  min-height: 0;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 20rpx;
  overflow: hidden;
  background-color: #E8E2D8;
}

.canvas-wrapper {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  padding: 6rpx;
  background-color: #E8E2D8;
  border-radius: 6rpx;
  box-shadow:
    inset 0 1rpx 4rpx rgba(255,255,255,0.5),
    0 2rpx 12rpx rgba(107,91,79,0.15);
}

.book-canvas {
  width: 100%;
  height: 100%;
  border-radius: 3rpx;
  background-color: transparent !important;
  display: block;
}

.book-canvas.zoomed {
  transform: scale(1.05);
}

/* 翻页指示点 */
.page-dots {
  position: absolute;
  top: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 12rpx;
  z-index: 10;
}

.page-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background-color: rgba(158, 148, 136, 0.4);
  transition: all 0.3s ease;
}

.page-dot.active {
  width: 24rpx;
  border-radius: 4rpx;
  background-color: #6B5B4F;
}

/* 加载中遮罩 */
.loading-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(250, 247, 242, 0.7);
  z-index: 20;
}

.loading-dot-wrap { display: flex; gap: 16rpx; }

.loading-dot {
  width: 16rpx; height: 16rpx;
  border-radius: 50%;
  background-color: #6B5B4F;
  animation: loadingBounce 1.4s ease-in-out infinite;
}
.loading-dot.d1 { animation-delay: 0s; }
.loading-dot.d2 { animation-delay: 0.2s; }
.loading-dot.d3 { animation-delay: 0.4s; }

@keyframes loadingBounce {
  0%, 80%, 100% { transform: scale(0); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

/* 字体加载中提示 */
.font-loading-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(250, 247, 242, 0.85);
  z-index: 25;
}

.font-loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 40rpx 48rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(107, 91, 79, 0.12);
}

.font-loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(158, 148, 136, 0.2);
  border-top-color: #6B5B4F;
  border-radius: 50%;
  animation: fontSpin 0.8s linear infinite;
}

@keyframes fontSpin {
  to { transform: rotate(360deg); }
}

.font-loading-text {
  font-size: 26rpx;
  color: #6B5B4F;
  font-weight: 500;
  letter-spacing: 1rpx;
  white-space: nowrap;
}

/* 空状态提示 */
.empty-hint {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  display: flex; flex-direction: column; align-items: center;
  gap: 16rpx; z-index: 5; pointer-events: none;
}
.empty-text { font-size: 36rpx; color: rgba(107,91,79,0.5); letter-spacing: 4rpx; }
.empty-sub { font-size: 24rpx; color: rgba(158,148,136,0.6); letter-spacing: 2rpx; }

/* ========== 工具栏（嵌入式，位于底部区域顶端）========== */
.toolbar-embedded {
  display: flex;
  align-items: center;
  justify-content: space-evenly;
  height: 48rpx;
  background-color: rgba(250, 247, 242, 0.98);
  border-bottom: 1rpx solid rgba(158, 148, 136, 0.15);
  flex-shrink: 0;
  position: relative;
  z-index: 10;
}

.tb-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 6rpx 24rpx;
  height: 40rpx;
}

.tb-btn--on { background-color: rgba(107, 91, 79, 0.1); border-radius: 10rpx; }
.tb-btn--save { background-color: rgba(107, 91, 79, 0.06); border-radius: 10rpx; }
.tb-txt { font-size: 20rpx; color: #6B5B4F; font-weight: 500; }
.tb-btn--on .tb-txt { color: #3D2B1F; font-weight: 600; }

/* ========== 底部区域（工具栏 + 输入框/设置面板）- 高度由JS动态计算 ========== */
.bottom-area {
  height: calc(580rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 100;
  overflow-y: auto;
  overflow-x: hidden;
  background-color: #FAF7F2;
  transition: height 0.2s ease-out;
}

/* ========== 设置面板（内嵌式，不遮挡 Canvas）========== */
.settings-panel {
  display: none;
  flex: 1;
  flex-direction: column;
  background-color: #FAF7F2;
  border-top: 1rpx solid rgba(158, 148, 136, 0.15);
  overflow: hidden;
  min-height: 0;
}

.settings-panel--visible {
  display: flex;
  animation: slideDown 0.25s ease-out;
}

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-12rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.settings-body {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom));
}

.settings-content {
  padding: 2rpx 10rpx;
  padding-bottom: 4rpx;
}

/* ===== 设置面板 - 紧凑布局 ===== */

.sp-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
  align-items: flex-start;
}
.sp-row:last-child {
  margin-bottom: 0;
}

.sp-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.sp-cell--full {
  flex: 0 0 100%;
  max-width: 100%;
}

.sp-cell--font {
  flex: 1.2;
}

.sp-cell--slider {
  flex: 1.5;
}

.sp-cell--small {
  flex: 1;
}

.sp-cell--paper {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.sp-cell--paper .sp-font-btn {
  padding: 6rpx 10rpx;
  min-height: 44rpx;
}

.sp-cell--paper .sp-font-text {
  font-size: 18rpx;
}

.sp-label {
  font-size: 24rpx;
  color: rgba(107, 91, 79, 0.7);
  line-height: 1.4;
  font-weight: 500;
}

/* 字体选择按钮 */
.sp-font-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 12rpx;
  background-color: rgba(255,255,255,0.9);
  border-radius: 8rpx;
  border: 1rpx solid rgba(158,148,136,0.2);
  min-height: 48rpx;
  gap: 8rpx;
}

.sp-font-preview {
  font-size: 24rpx;
  color: #3D2B1F;
  flex: 0 0 auto;
}

.sp-font-name {
  font-size: 24rpx;
  color: rgba(107,91,79,0.5);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sp-arrow {
  font-size: 32rpx;
  color: rgba(158,148,136,0.5);
  flex-shrink: 0;
}

/* 按钮组 */
.sp-btns {
  display: flex;
  gap: 8rpx;
}

.sp-btn {
  flex: 1;
  padding: 10rpx 12rpx;
  font-size: 24rpx;
  text-align: center;
  color: rgba(107,91,79,0.7);
  background-color: rgba(255,255,255,0.7);
  border-radius: 8rpx;
  border: 1rpx solid rgba(158,148,136,0.2);
  min-height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 500;
}

.sp-btn.active {
  background-color: #6B5B4F;
  color: #FAF7F2;
  border-color: #6B5B4F;
}

/* 芯片选择器 */
.sp-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.sp-chips--compact {
  gap: 6rpx;
}

.sp-chips--paper {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.sp-chip {
  padding: 8rpx 12rpx;
  font-size: 24rpx;
  color: #6B5B4F;
  background-color: rgba(255,255,255,0.8);
  border-radius: 8rpx;
  border: 1rpx solid rgba(158,148,136,0.2);
  min-height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 500;
}

.sp-chip.active {
  background-color: #6B5B4F;
  color: #FAF7F2;
  border-color: #6B5B4F;
}

.sp-chips--compact .sp-chip {
  padding: 8rpx 12rpx;
  min-height: 40rpx;
  font-size: 22rpx;
}

/* 颜色选择 */
.sp-colors {
  display: flex;
  gap: 8rpx;
  align-items: center;
  flex-wrap: wrap;
}

.sp-colors--expanded {
  gap: 6rpx;
}

.sp-colors--paper {
  display: flex;
  gap: 6rpx;
  align-items: center;
}

.sp-colors--paper-expanded {
  gap: 5rpx;
  flex-wrap: wrap;
}

.sp-color {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(158,148,136,0.3);
  flex-shrink: 0;
  box-shadow: 0 1rpx 3rpx rgba(0,0,0,0.08);
}

.sp-color.active {
  border: 2rpx solid #6B5B4F;
  transform: scale(1.1);
  box-shadow: 0 0 0 2rpx rgba(107,91,79,0.15), 0 2rpx 6rpx rgba(0,0,0,0.12);
}

.sp-colors--expanded .sp-color,
.sp-colors--paper-expanded .sp-color {
  width: 26rpx;
  height: 26rpx;
}

/* 滑动条 */
.sp-slider {
  flex: 1;
  margin: 0;
  min-height: 36rpx;
}

.sp-slider--mini {
  flex: 1;
  margin: 0;
  min-height: 32rpx;
}

/* 边距网格 */
.sp-margins {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10rpx 12rpx;
}

.sp-margins--compact {
  gap: 8rpx 10rpx;
}

.sp-margin-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.sp-margin-label {
  font-size: 24rpx;
  color: rgba(107,91,79,0.6);
  width: 28rpx;
  text-align: center;
  flex-shrink: 0;
  font-weight: 500;
}

.sp-margin-val {
  font-size: 24rpx;
  color: #6B5B4F;
  min-width: 36rpx;
  text-align: right;
  flex-shrink: 0;
  font-weight: 500;
}

/* 底部操作栏 */
.sp-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 16rpx calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(158,148,136,0.12);
  flex-shrink: 0;
  gap: 8rpx;
  background-color: #FAF7F2;
  z-index: 10;
}

.sp-footer-btn {
  flex: 1;
  padding: 10rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 500;
  min-height: 40rpx;
}

.sp-footer-btn--reset {
  color: rgba(107,91,79,0.7);
  background-color: rgba(255,255,255,0.7);
  border: 1rpx solid rgba(158,148,136,0.2);
}

.sp-footer-btn--reset:active {
  background-color: rgba(158,148,136,0.15);
}

.sp-footer-btn--default {
  color: rgba(107,91,79,0.6);
  background-color: rgba(158,148,136,0.12);
  border: 1rpx solid rgba(158,148,136,0.15);
}

.sp-footer-btn--default:active {
  background-color: rgba(158,148,136,0.25);
}

.sp-footer-btn--done {
  color: #FAF7F2;
  font-weight: 600;
  background-color: #6B5B4F;
}

.sp-footer-btn--done:active {
  opacity: 0.85;
}

/* ========== 输入区 - 键盘弹出时动态适配 ========== */
.input-area {
  display: flex;
  flex-direction: column;
  background-color: #FAF7F2;
  border-top: none;
  padding: 6rpx 20rpx 0;
  overflow: visible;
  flex-shrink: 0;
  transition: height 0.2s ease-out;
}

.input-area--hidden {
  display: none;
}

/* ========== 全屏编辑遮罩（输入框全屏）========== */
.fullscreen-edit-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  background-color: #FFFFFF;
  display: flex;
  flex-direction: column;
}

.fullscreen-header {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  padding-top: calc(60rpx + env(safe-area-inset-top));
  background-color: #FFFFFF;
  border-bottom: 1rpx solid #EEE;
  flex-shrink: 0;
}

.fs-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.fs-btn {
  font-size: 26rpx;
  color: #576B95;
  padding: 8rpx 24rpx;
  background-color: rgba(0,0,0,0.04);
  border-radius: 8rpx;
}
.fs-btn--clear {
  background-color: transparent;
  color: #999;
}
.fs-btn--done {
  background-color: #576B95;
  color: #FFFFFF;
  font-weight: 500;
  padding: 10rpx 36rpx;
}

.fullscreen-textarea {
  width: 100%;
  padding: 28rpx 32rpx;
  box-sizing: border-box;
  font-size: 32rpx;
  line-height: 1.8;
  color: #1A1A1A;
  background-color: #FFFFFF;
}

.fullscreen-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 28rpx;
  padding-bottom: calc(110rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #EEE;
  flex-shrink: 0;
  background-color: #FFFFFF;
}

.fs-char-count {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

.fs-btn-group {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.fs-btn--exit {
  background-color: transparent;
  color: #999;
}

.text-input {
  flex: 1;
  width: 100%;
  min-height: 80rpx;
  background-color: #FFFFFF;
  border-radius: 10rpx;
  padding: 16rpx 18rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #3D2B1F;
  box-sizing: border-box;
  border: 1rpx solid rgba(158,148,136,0.25);
  transition: height 0.2s ease-out;
}

.input-placeholder { color: rgba(158,148,136,0.6); font-size: 24rpx; }

.input-toolbar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 4rpx 4rpx calc(8rpx + env(safe-area-inset-bottom));
  flex-shrink: 0;
  min-height: 36rpx;
}
.input-toolbar--hidden { display: none; }
.input-actions-left { display: flex; align-items: center; }
.char-count { font-size: 18rpx; color: rgba(158,148,136,0.7); }
.input-actions-right { display: flex; align-items: center; gap: 12rpx; }
.action-btn { font-size: 22rpx; color: #6B5B4F; padding: 6rpx 10rpx; }
.action-btn:active { color: #3D2B1F; }
.action-btn--small {
  font-size: 20rpx;
  color: #8B7E72;
  padding: 4rpx 12rpx;
  background-color: rgba(158, 148, 136, 0.1);
  border-radius: 6rpx;
}
.action-btn--small:active {
  background-color: rgba(158, 148, 136, 0.2);
}

/* ========== 字体选择弹窗（fixed）========== */
.font-panel {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0,0,0,0.45); z-index: 10002; display: none;
  align-items: flex-end; justify-content: center;
}
.font-panel--visible { display: flex; }

.font-panel-content {
  width: 100%;
  max-height: 85vh;
  background-color: #FAF7F2;
  border-radius: 24rpx 24rpx 0 0;
  display: flex; flex-direction: column;
  animation: slideUp 0.3s ease-out;
}

.font-panel-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 18rpx 20rpx 12rpx;
  border-bottom: 1rpx solid rgba(158,148,136,0.15);
  flex-shrink: 0;
}
.font-panel-back { font-size: 28rpx; color: #6B5B4F; padding: 8rpx 12rpx 8rpx 0; }
.font-panel-title { font-size: 30rpx; color: #3D2B1F; font-weight: 600; margin-right: auto; margin-left: 20rpx; }
.font-panel-close { font-size: 30rpx; color: rgba(107,91,79,0.5); padding: 8rpx; }

.font-tip {
  padding: 10rpx 20rpx;
  background-color: rgba(255, 248, 220, 0.6);
  border-bottom: 1rpx solid rgba(158,148,136,0.1);
}
.font-tip-text {
  font-size: 18rpx;
  color: rgba(107,91,79,0.7);
  line-height: 1.4;
}

.font-grid { 
  flex: 1; 
  min-height: 0; 
  padding: 12rpx; 
}
.font-grid-inner {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 10rpx;
}
.font-grid-item {
  display: flex; 
  flex-direction: column; 
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 10rpx 6rpx; 
  border-radius: 8rpx;
  background-color: rgba(255,255,255,0.9);
  border: 2rpx solid transparent;
  transition: all 0.2s;
  position: relative;
  overflow: hidden;
}
.font-grid-item:active { background-color: rgba(158,148,136,0.12); }
.font-grid-item.active { 
  background-color: rgba(107,91,79,0.1); 
  border-color: #6B5B4F;
}
.font-main {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}
.font-name { 
  font-size: 16rpx; 
  color: #3D2B1F; 
  font-weight: 500; 
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
}
.font-meta {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
}
.font-size { 
  font-size: 20rpx; 
  color: rgba(158,148,136,0.6); 
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.font-status-tag {
  font-size: 16rpx;
  color: rgba(200, 80, 60, 0.75);
  margin-left: 6rpx;
  padding: 1rpx 6rpx;
  border-radius: 4rpx;
  background-color: rgba(200, 80, 60, 0.06);
}

.font-status-tag.loaded {
  color: rgba(80, 140, 100, 0.85);
  background-color: rgba(80, 140, 100, 0.08);
}
.font-check { 
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  font-size: 22rpx; 
  color: #6B5B4F; 
  font-weight: 600; 
  background-color: rgba(255,255,255,0.95);
  border-radius: 50%;
  width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.1);
}

/* ========== 模板预览选择区域 ========== */

/* 纸张模板设置项样式 */
.settings-cell--template {
  cursor: pointer;
  position: relative;
}

.settings-cell--template:active {
  background: rgba(158, 148, 136, 0.15);
}

.template-mini-preview {
  width: 24rpx;
  height: 30rpx;
  border-radius: 2rpx;
  border: 1rpx solid rgba(158, 148, 136, 0.3);
  flex-shrink: 0;
}

.template-preview-section {
  padding: 16rpx 20rpx 20rpx;
  background-color: rgba(250,247,242,0.6);
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.template-section-title {
  font-size: 28rpx;
  color: #5C4D40;
  font-weight: 600;
  margin-bottom: 16rpx;
  display: block;
}

.template-swiper {
  height: 320rpx;
}

.template-preview-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  padding: 0 8rpx;
}

.template-preview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  cursor: pointer;
  padding: 10rpx;
  border-radius: 10rpx;
  transition: all 0.2s ease;
}

.template-preview-item.active {
  background-color: rgba(107,91,79,0.15);
}

.template-preview-box {
  width: 100%;
  aspect-ratio: 3/4;
  border-radius: 8rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.12);
  margin-bottom: 10rpx;
}

.template-preview-bg {
  width: 100%;
  height: 100%;
  position: absolute;
}

.template-preview-fiber {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    repeating-linear-gradient(90deg, 
      rgba(180,170,160,0.03) 0px, 
      rgba(180,170,160,0.03) 1px, 
      transparent 1px, 
      transparent 3px),
    repeating-linear-gradient(0deg, 
      rgba(180,170,160,0.02) 0px, 
      rgba(180,170,160,0.02) 1px, 
      transparent 1px, 
      transparent 4px);
}

.template-preview-border {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  right: 12rpx;
  bottom: 12rpx;
  border: 1rpx solid rgba(200, 185, 165, 0.4);
  border-radius: 2rpx;
}

.template-preview-watermark {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 32rpx;
  color: rgba(120, 105, 90, 0.05);
  font-family: serif;
  letter-spacing: 4rpx;
}

.template-preview-lines {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  right: 16rpx;
  bottom: 16rpx;
  background-image: repeating-linear-gradient(to bottom, 
    transparent 0rpx, 
    transparent 30rpx, 
    rgba(150, 135, 120, 0.06) 30rpx, 
    rgba(150, 135, 120, 0.06) 32rpx);
}

.template-preview-grid-lines {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  right: 12rpx;
  bottom: 12rpx;
  background-image: 
    repeating-linear-gradient(to bottom, 
      transparent 0rpx, 
      transparent 24rpx, 
      rgba(150, 135, 120, 0.06) 24rpx, 
      rgba(150, 135, 120, 0.06) 26rpx),
    repeating-linear-gradient(to right, 
      transparent 0rpx, 
      transparent 24rpx, 
      rgba(150, 135, 120, 0.06) 24rpx, 
      rgba(150, 135, 120, 0.06) 26rpx);
}

.template-preview-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    linear-gradient(135deg, rgba(255,255,255,0.1) 0%, transparent 40%),
    linear-gradient(225deg, transparent 60%, rgba(0,0,0,0.04) 100%);
  pointer-events: none;
}

.template-preview-name {
  font-size: 22rpx;
  color: #6B5B4F;
  text-align: center;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
}

.template-preview-check {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  background-color: #6B5B4F;
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
}

.template-indicators {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 16rpx;
}

.template-indicator {
  width: 16rpx;
  height: 6rpx;
  background-color: rgba(158,148,136,0.3);
  border-radius: 3rpx;
  transition: all 0.2s ease;
}

.template-indicator.active {
  width: 32rpx;
  background-color: #6B5B4F;
}

/* ========== 模板选择弹窗（fixed）========== */
.template-panel {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0,0,0,0.45); z-index: 10002; display: none;
  align-items: flex-end; justify-content: center;
}
.template-panel--visible { display: flex; }

.template-panel-content {
  width: 100%;
  max-height: 85vh;
  background-color: #FAF7F2;
  border-radius: 24rpx 24rpx 0 0;
  display: flex; flex-direction: column;
  animation: slideUp 0.3s ease-out;
}

.template-panel-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 24rpx 16rpx;
  border-bottom: 1rpx solid rgba(158,148,136,0.15);
  flex-shrink: 0;
}
.template-panel-title { font-size: 30rpx; color: #3D2B1F; font-weight: 600; }
.template-panel-close { font-size: 32rpx; color: rgba(107,91,79,0.5); padding: 8rpx; }

.template-grid { flex: 1; min-height: 0; padding: 10rpx 0; }
.template-grid-inner {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 10rpx;
  padding: 12rpx 16rpx;
}
.template-grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 8rpx;
  border-radius: 12rpx;
  background-color: rgba(255,255,255,0.8);
  border: 2rpx solid transparent;
  transition: all 0.2s;
  position: relative;
  overflow: hidden;
}
.template-grid-item:active { background-color: rgba(158,148,136,0.1); }
.template-grid-item.active { 
  background-color: rgba(107,91,79,0.08);
  border-color: #6B5B4F;
}
.template-preview {
  width: 100%;
  height: 110rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background-color: rgba(158,148,136,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}
.template-preview-img {
  width: 100%;
  height: 100%;
}
.template-info {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.template-name {
  font-size: 15rpx;
  color: #3D2B1F;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
  font-weight: 500;
}
.template-check {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  font-size: 18rpx;
  color: #6B5B4F;
  font-weight: 600;
  background-color: rgba(255,255,255,0.95);
  border-radius: 50%;
  width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 1rpx 4rpx rgba(0,0,0,0.12);
}

/* ========== 保存选项弹窗（fixed）========== */
.save-panel {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0,0,0,0.45); z-index: 10002; display: none;
  align-items: flex-end; justify-content: center;
}
.save-panel--visible { display: flex; }

.save-panel-content {
  width: 100%;
  background-color: #FAF7F2;
  border-radius: 24rpx 24rpx 0 0;
  display: flex; flex-direction: column;
  animation: slideUp 0.3s ease-out;
}

.save-panel-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 24rpx 16rpx;
  border-bottom: 1rpx solid rgba(158,148,136,0.15);
}
.save-panel-title { font-size: 30rpx; color: #3D2B1F; font-weight: 600; }
.save-panel-close { font-size: 32rpx; color: rgba(107,91,79,0.5); padding: 8rpx; }

.save-options {
  display: flex;
  padding: 28rpx 24rpx;
  gap: 20rpx;
}

.save-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 32rpx 16rpx;
  background-color: rgba(255,255,255,0.85);
  border-radius: 16rpx;
  border: 1rpx solid rgba(158,148,136,0.2);
}

.save-option-icon { font-size: 52rpx; }
.save-option-label { font-size: 24rpx; color: #3D2B1F; font-weight: 500; }

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* ===== 新文字设置样式 ===== */
