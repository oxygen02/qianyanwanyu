.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(96rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background-color: #F5F0E8;
  border-top: 1rpx solid rgba(158, 148, 136, 0.2);
  display: flex;
  flex-direction: row;
  align-items: center;
  z-index: 9999;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  position: relative;
}

.tab-bar-text {
  font-size: 28rpx;
  color: #9E9488;
  font-family: serif;
  letter-spacing: 0.1em;
  transition: color 0.3s;
}

.tab-bar-item.active .tab-bar-text {
  color: #3D2B1F;
  font-weight: 600;
}

/* 选中指示条 */
.tab-bar-item.active::after {
  content: '';
  position: absolute;
  bottom: 12rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background-color: #3D2B1F;
  border-radius: 2rpx;
}