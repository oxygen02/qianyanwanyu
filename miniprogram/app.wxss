/* app.wxss - 全局基础样式 */
page {
  background-color: #F5F0E8;
  font-family: serif;
  -webkit-font-smoothing: antialiased;
}

/* 清除默认margin/padding - WXSS不支持*通配符，改用page继承 */
page {
  box-sizing: border-box;
}

/* 全局box-sizing */
view, text, image, navigator, button, input, textarea {
  box-sizing: border-box;
}

/* 通用布局 */
.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-1 {
  flex: 1;
}

/* 文字颜色系统 */
.text-primary {
  color: #3D2B1F;
}

.text-secondary {
  color: #9E9488;
}

/* 页面容器 - 全屏 */
.page-container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #F5F0E8;
  overflow: hidden;
}
